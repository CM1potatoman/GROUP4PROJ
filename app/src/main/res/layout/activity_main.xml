<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#87CEEB"
    android:padding="16dp">

    <!-- START SCREEN -->
    <LinearLayout
        android:id="@+id/startLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Group 4 Quizz"
            android:textSize="32sp"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <ImageView
            android:id="@+id/spinmaelImage"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:scaleType="fitCenter"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SPINMAEL"
            android:textSize="24sp"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/startButton"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            android:text="START"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- CATEGORY SELECTION SCREEN (Limbus ID Style) -->
    <LinearLayout
        android:id="@+id/categoryLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose Your Section"
            android:textSize="28sp"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <!-- HTML/CSS Card -->
        <LinearLayout
            android:id="@+id/category1Btn"
            android:layout_width="280dp"
            android:layout_height="120dp"
            android:background="@drawable/id_card_bg"
            android:orientation="horizontal"
            android:padding="8dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/cat1Icon"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/css" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:paddingStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Section 1"
                    android:textColor="#0000FF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HTML/CSS"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- JAVA Card -->
        <LinearLayout
            android:id="@+id/category2Btn"
            android:layout_width="280dp"
            android:layout_height="120dp"
            android:background="@drawable/id_card_bg"
            android:orientation="horizontal"
            android:padding="8dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/cat2Icon"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/javimg" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:paddingStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Section 2"
                    android:textColor="#0000FF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JAVA"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- KOTLIN Card -->
        <LinearLayout
            android:id="@+id/category3Btn"
            android:layout_width="280dp"
            android:layout_height="120dp"
            android:background="@drawable/id_card_bg"
            android:orientation="horizontal"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/cat3Icon"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/kotpng" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:paddingStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Section 3"
                    android:textColor="#0000FF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KOTLIN"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Rhythm Game Button -->
        <LinearLayout
            android:id="@+id/rhythmBtn"
            android:layout_width="280dp"
            android:layout_height="120dp"
            android:background="@drawable/id_card_bg"
            android:orientation="horizontal"
            android:padding="8dp"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/spinmael" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:paddingStart="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPECIAL"
                    android:textColor="#0000FF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Children of the City"
                    android:textColor="#000000"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- RHYTHM GAME SCREEN -->
    <RelativeLayout
        android:id="@+id/rhythmLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Info Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">
            <TextView
                android:id="@+id/rhythmScoreText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Score: 0"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/rhythmTimerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3:50"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Area where notes fall -->
        <FrameLayout
            android:id="@+id/noteLaneLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="120dp" />

        <!-- Target Zone (Receptors at Bottom) -->
        <LinearLayout
            android:id="@+id/receptorLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:orientation="horizontal">
            <ImageView android:id="@+id/receptorLeft" android:layout_width="80dp" android:layout_height="80dp" android:src="@drawable/ic_arrow_left" android:alpha="0.4" android:layout_margin="4dp" android:clickable="true" android:focusable="true"/>
            <ImageView android:id="@+id/receptorDown" android:layout_width="80dp" android:layout_height="80dp" android:src="@drawable/ic_arrow_down" android:alpha="0.4" android:layout_margin="4dp" android:clickable="true" android:focusable="true"/>
            <ImageView android:id="@+id/receptorUp" android:layout_width="80dp" android:layout_height="80dp" android:src="@drawable/ic_arrow_up" android:alpha="0.4" android:layout_margin="4dp" android:clickable="true" android:focusable="true"/>
            <ImageView android:id="@+id/receptorRight" android:layout_width="80dp" android:layout_height="80dp" android:src="@drawable/ic_arrow_right" android:alpha="0.4" android:layout_margin="4dp" android:clickable="true" android:focusable="true"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- QUIZ SCREEN -->
    <LinearLayout
        android:id="@+id/quizLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/progressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="Question 0 of 0"
            android:textColor="#000000"
            android:textSize="16sp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_margin="16dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <TextView
                android:id="@+id/questionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:layout_margin="32dp"
                android:textColor="#000000"
                android:text="Question text here?"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- faust stays in the right corner -->
            <ImageView
                android:id="@+id/faustSprite"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_alignParentBottom="true"
                android:layout_alignParentEnd="true"
                android:scaleType="fitCenter" />

            <!-- xi stays in the left corner -->
            <ImageView
                android:id="@+id/xiSprite"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_alignParentBottom="true"
                android:layout_alignParentStart="true"
                android:scaleType="fitCenter" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/option1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/kahoot_red"
                    android:text="Option A" />

                <Button
                    android:id="@+id/option2"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="@color/kahoot_blue"
                    android:text="Option B" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/option3"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:backgroundTint="@color/kahoot_yellow"
                    android:text="Option C" />

                <Button
                    android:id="@+id/option4"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:backgroundTint="@color/kahoot_green"
                    android:text="Option D" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- RESULT SCREEN -->
    <LinearLayout
        android:id="@+id/resultLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/scoreText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quiz Finished!"
            android:textColor="#000000"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detailedScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Correct: 0 | Wrong: 0"
            android:textColor="#000000"
            android:textSize="20sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/restartButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            android:text="Play Again" />
    </LinearLayout>

</FrameLayout>